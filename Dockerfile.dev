FROM node:20-alpine
RUN apk add --no-cache libc6-compat
RUN corepack enable
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1

# Install the whole workspace (cached unless any manifest changes).
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml .npmrc turbo.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/db/package.json ./packages/db/
COPY packages/config/package.json ./packages/config/
RUN pnpm install --frozen-lockfile

# Generate the Prisma client (schema copied here; source is bind-mounted at runtime).
COPY packages/db ./packages/db
RUN pnpm --filter @progressio/db generate

EXPOSE 3000
CMD ["pnpm", "--filter", "@progressio/web", "exec", "next", "dev"]
