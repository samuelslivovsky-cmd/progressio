generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  TRAINER
  CLIENT
}

enum MeasurementUnit {
  KG
  LBS
  CM
  INCH
}

enum AlertType {
  INACTIVE
  PLATEAU
  LOW_ADHERENCE
  SKIPPED_EXERCISE
  DROP_OFF_RISK
  GOAL_REACHED
  MILESTONE
}

// ─── Auth Models ────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  refreshSessions RefreshSession[]
  profile       Profile?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model RefreshSession {
  id        String    @id @default(cuid())   // tokenId (also the jti in the cookie)
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId  String    @map("family_id")
  userAgent String?   @map("user_agent")
  ip        String?
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([familyId])
  @@map("refresh_sessions")
}

// ─── App Models ─────────────────────────────────────────────────────

model Profile {
  id               String   @id @default(cuid())
  userId           String   @unique @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role             Role
  name             String
  email            String   @unique
  avatarUrl        String?  @map("avatar_url")
  goalWeight       Decimal? @map("goal_weight") @db.Decimal(6, 2)
  height           Decimal? @map("height") @db.Decimal(5, 2)
  age              Int?     @map("age")
  activityLevel    String?  @map("activity_level")
  subscriptionTier String   @default("FREE") @map("subscription_tier")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Trainer relations
  clients       ClientTrainer[] @relation("TrainerClients")
  mealPlans     MealPlan[]
  mealTemplates MealTemplate[]
  trainingPlans TrainingPlan[]

  // Client relations
  trainerRelation       ClientTrainer?           @relation("ClientProfile")
  weightLogs            WeightLog[]
  measurements          Measurement[]
  foodLogs              FoodLog[]
  workoutLogs           WorkoutLog[]
  assignedMealPlan      MealPlanAssignment[]
  assignedTrainingPlan  TrainingPlanAssignment[]
  clientTrainingPlans   ClientTrainingPlan[]
  alertsAsTrainer       Alert[]                  @relation("AlertTrainer")
  alertsAsClient        Alert[]                  @relation("AlertClient")
  analyticsSnapshots   AnalyticsSnapshot[]
  weeklySummaries       WeeklySummary[]
  aiChatMessages        AiChatMessage[]
  customExercises       Exercise[]               @relation("CustomExercises")

  @@map("profiles")
}

model ClientTrainer {
  id        String   @id @default(cuid())
  client    Profile  @relation("ClientProfile", fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String   @unique @map("client_id")
  trainer   Profile  @relation("TrainerClients", fields: [trainerId], references: [id], onDelete: Cascade)
  trainerId String   @map("trainer_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("client_trainer")
}

model Alert {
  id        String    @id @default(cuid())
  trainer   Profile   @relation("AlertTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  trainerId String    @map("trainer_id")
  client    Profile   @relation("AlertClient", fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String    @map("client_id")
  type      AlertType
  severity  String
  message   String
  resolved  Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([trainerId, resolved])
  @@index([clientId, resolved])
  @@map("alerts")
}

model AnalyticsSnapshot {
  id                String   @id @default(cuid())
  client            Profile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId          String   @map("client_id")
  date              DateTime @db.Date
  adherenceScore    Float    @map("adherence_score")
  calorieAdherence  Float    @map("calorie_adherence")
  trainingAdherence Float    @map("training_adherence")
  dropOffScore      Float    @map("drop_off_score")
  createdAt         DateTime @default(now()) @map("created_at")

  @@unique([clientId, date])
  @@map("analytics_snapshots")
}

model WeeklySummary {
  id         String   @id @default(cuid())
  client     Profile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId   String   @map("client_id")
  weekStart  DateTime @map("week_start") @db.Date
  content    String   // AI-generated markdown text
  highlights Json?    // { adherence, avgKcal, weightDelta, workoutsCompleted }
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([clientId, weekStart])
  @@map("weekly_summaries")
}

// ─── Weight & Measurements ───────────────────────────────────────────

model WeightLog {
  id        String          @id @default(cuid())
  profile   Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String          @map("profile_id")
  weight    Decimal         @db.Decimal(6, 2)
  unit      MeasurementUnit @default(KG)
  note      String?
  loggedAt  DateTime        @default(now()) @map("logged_at")

  @@index([profileId, loggedAt])
  @@map("weight_logs")
}

model Measurement {
  id        String          @id @default(cuid())
  profile   Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String          @map("profile_id")
  chest     Decimal?        @db.Decimal(5, 2)
  waist     Decimal?        @db.Decimal(5, 2)
  hips      Decimal?        @db.Decimal(5, 2)
  thigh     Decimal?        @db.Decimal(5, 2)
  arm       Decimal?        @db.Decimal(5, 2)
  calf      Decimal?        @db.Decimal(5, 2)
  neck      Decimal?        @db.Decimal(5, 2)
  unit      MeasurementUnit @default(CM)
  note      String?
  loggedAt  DateTime        @default(now()) @map("logged_at")

  @@index([profileId, loggedAt])
  @@map("measurements")
}

// ─── Food & Nutrition ────────────────────────────────────────────────

model Food {
  id          String  @id @default(cuid())
  name        String
  calories    Decimal @db.Decimal(7, 2)
  protein     Decimal @db.Decimal(6, 2)
  carbs       Decimal @db.Decimal(6, 2)
  fat         Decimal @db.Decimal(6, 2)
  fiber       Decimal @default(0) @db.Decimal(6, 2)
  servingSize Decimal @default(100) @map("serving_size") @db.Decimal(7, 2)
  unit        String  @default("g")
  barcode     String? @unique

  foodLogItems      FoodLogItem[]
  mealItems         MealItem[]
  mealTemplateItems MealTemplateItem[]

  @@map("foods")
}

model FoodLog {
  id        String        @id @default(cuid())
  profile   Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String        @map("profile_id")
  date      DateTime      @db.Date
  items     FoodLogItem[]
  note      String?
  createdAt DateTime      @default(now()) @map("created_at")

  @@unique([profileId, date])
  @@map("food_logs")
}

model FoodLogItem {
  id         String  @id @default(cuid())
  foodLog    FoodLog @relation(fields: [foodLogId], references: [id], onDelete: Cascade)
  foodLogId  String  @map("food_log_id")
  food       Food?   @relation(fields: [foodId], references: [id], onDelete: SetNull)
  foodId     String? @map("food_id")
  customName String? @map("custom_name")
  amount     Decimal @db.Decimal(7, 2)
  mealType   String  @map("meal_type") // breakfast, desiata, lunch, olovrant, dinner

  @@index([foodLogId])
  @@map("food_log_items")
}

// ─── Meal Plans ──────────────────────────────────────────────────────

model MealPlan {
  id                  String               @id @default(cuid())
  trainer             Profile              @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  trainerId           String               @map("trainer_id")
  name                String
  description         String?
  calorieTargetPerDay Int?                 @map("calorie_target_per_day")
  days                MealPlanDay[]
  assignments         MealPlanAssignment[]
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  @@map("meal_plans")
}

model MealPlanDay {
  id         String   @id @default(cuid())
  mealPlan   MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  mealPlanId String   @map("meal_plan_id")
  dayNumber  Int      @map("day_number") // 1-7
  meals      Meal[]

  @@index([mealPlanId])
  @@map("meal_plan_days")
}

model Meal {
  id            String      @id @default(cuid())
  mealPlanDay   MealPlanDay @relation(fields: [mealPlanDayId], references: [id], onDelete: Cascade)
  mealPlanDayId String      @map("meal_plan_day_id")
  name          String // breakfast, desiata, lunch, olovrant, dinner
  items         MealItem[]

  @@index([mealPlanDayId])
  @@map("meals")
}

model MealItem {
  id     String  @id @default(cuid())
  meal   Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)
  mealId String  @map("meal_id")
  food   Food    @relation(fields: [foodId], references: [id], onDelete: Restrict)
  foodId String  @map("food_id")
  amount Decimal @db.Decimal(7, 2)

  @@index([mealId])
  @@map("meal_items")
}

model MealPlanAssignment {
  id         String    @id @default(cuid())
  client     Profile   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId   String    @map("client_id")
  mealPlan   MealPlan  @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  mealPlanId String    @map("meal_plan_id")
  startDate  DateTime  @map("start_date")
  endDate    DateTime? @map("end_date")
  note       String?

  @@map("meal_plan_assignments")
}

// ─── Meal templates (uložené jedlá) ───────────────────────────────────

model MealTemplate {
  id        String             @id @default(cuid())
  trainer   Profile            @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  trainerId String             @map("trainer_id")
  name      String
  items     MealTemplateItem[]
  createdAt DateTime           @default(now()) @map("created_at")

  @@map("meal_templates")
}

model MealTemplateItem {
  id             String       @id @default(cuid())
  mealTemplate   MealTemplate @relation(fields: [mealTemplateId], references: [id], onDelete: Cascade)
  mealTemplateId String       @map("meal_template_id")
  food           Food         @relation(fields: [foodId], references: [id], onDelete: Restrict)
  foodId         String       @map("food_id")
  amount         Decimal      @db.Decimal(7, 2)

  @@map("meal_template_items")
}

// ─── Training ────────────────────────────────────────────────────────

model Exercise {
  id           String   @id @default(cuid())
  externalId   String?  @unique @map("external_id") // ExerciseDB API id
  name         String
  description  String?
  muscleGroups String[] @map("muscle_groups")
  equipment    String?
  videoUrl     String?  @map("video_url")
  createdById  String?  @map("created_by_id")
  createdBy    Profile? @relation("CustomExercises", fields: [createdById], references: [id], onDelete: SetNull)

  trainingPlanExercises     TrainingPlanExercise[]
  clientTrainingPlanExercises ClientTrainingPlanExercise[]
  workoutLogItems           WorkoutLogItem[]

  @@index([createdById])
  @@map("exercises")
}

model TrainingPlan {
  id          String                   @id @default(cuid())
  trainer     Profile                  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  trainerId   String                   @map("trainer_id")
  name        String
  description String?
  days        TrainingPlanDay[]
  assignments TrainingPlanAssignment[]
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")

  @@map("training_plans")
}

model TrainingPlanDay {
  id             String                 @id @default(cuid())
  trainingPlan   TrainingPlan           @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  trainingPlanId String                 @map("training_plan_id")
  dayNumber      Int                    @map("day_number")
  name           String? // e.g. "Push Day", "Legs"
  isRestDay      Boolean                @default(false) @map("is_rest_day")
  exercises      TrainingPlanExercise[]

  @@index([trainingPlanId])
  @@map("training_plan_days")
}

model TrainingPlanExercise {
  id                String          @id @default(cuid())
  trainingPlanDay   TrainingPlanDay @relation(fields: [trainingPlanDayId], references: [id], onDelete: Cascade)
  trainingPlanDayId String          @map("training_plan_day_id")
  exercise          Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  exerciseId        String          @map("exercise_id")
  sets              Int
  reps              String // can be "8-12" or "10"
  restSeconds       Int?            @map("rest_seconds")
  note              String?
  order             Int

  @@index([trainingPlanDayId])
  @@map("training_plan_exercises")
}

model TrainingPlanAssignment {
  id             String       @id @default(cuid())
  client         Profile      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId       String       @map("client_id")
  trainingPlan   TrainingPlan @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  trainingPlanId String       @map("training_plan_id")
  startDate      DateTime     @map("start_date")
  endDate        DateTime?    @map("end_date")

  @@map("training_plan_assignments")
}

// Vlastný tréningový plán klienta (bez trénera)
model ClientTrainingPlan {
  id          String                     @id @default(cuid())
  profile     Profile                    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId   String                     @map("profile_id")
  name        String
  description String?
  days        ClientTrainingPlanDay[]
  createdAt   DateTime                   @default(now()) @map("created_at")
  updatedAt   DateTime                   @updatedAt @map("updated_at")

  @@map("client_training_plans")
}

model ClientTrainingPlanDay {
  id                   String                        @id @default(cuid())
  clientTrainingPlan   ClientTrainingPlan             @relation(fields: [clientTrainingPlanId], references: [id], onDelete: Cascade)
  clientTrainingPlanId String                        @map("client_training_plan_id")
  dayNumber            Int                           @map("day_number")
  name                 String?                       // e.g. "Push", "Nohy"
  isRestDay            Boolean                       @default(false) @map("is_rest_day")
  exercises            ClientTrainingPlanExercise[]

  @@map("client_training_plan_days")
}

model ClientTrainingPlanExercise {
  id                   String                @id @default(cuid())
  clientTrainingPlanDay ClientTrainingPlanDay @relation(fields: [clientTrainingPlanDayId], references: [id], onDelete: Cascade)
  clientTrainingPlanDayId String              @map("client_training_plan_day_id")
  exercise             Exercise              @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  exerciseId           String                @map("exercise_id")
  sets                 Int
  reps                 String                // e.g. "10" or "8-12"
  restSeconds          Int?                  @map("rest_seconds")
  note                 String?
  order                Int

  @@map("client_training_plan_exercises")
}

model WorkoutLog {
  id          String           @id @default(cuid())
  profile     Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId   String           @map("profile_id")
  date        DateTime         @db.Date
  name        String?
  durationMin Int?             @map("duration_min")
  items       WorkoutLogItem[]
  note        String?
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([profileId, date])
  @@map("workout_logs")
}

model WorkoutLogItem {
  id           String       @id @default(cuid())
  workoutLog   WorkoutLog   @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  workoutLogId String       @map("workout_log_id")
  exercise     Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  exerciseId   String       @map("exercise_id")
  sets         WorkoutSet[]

  @@index([workoutLogId])
  @@map("workout_log_items")
}

model WorkoutSet {
  id               String         @id @default(cuid())
  workoutLogItem   WorkoutLogItem @relation(fields: [workoutLogItemId], references: [id], onDelete: Cascade)
  workoutLogItemId String         @map("workout_log_item_id")
  reps             Int?
  weightKg         Decimal?       @map("weight_kg") @db.Decimal(6, 2)
  durationSec      Int?           @map("duration_sec")
  note             String?

  @@index([workoutLogItemId])
  @@map("workout_sets")
}

// ─── AI (Klient AI tier) ─────────────────────────────────────────────

model AiChatMessage {
  id        String   @id @default(cuid())
  client    Profile  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String   @map("client_id")
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([clientId, createdAt])
  @@map("ai_chat_messages")
}
