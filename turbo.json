{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "DIRECT_URL",
    "REDIS_URL",
    "JWT_ACCESS_SECRET",
    "ACCESS_TOKEN_TTL",
    "REFRESH_TOKEN_TTL",
    "NEXT_PUBLIC_APP_URL",
    "NEXT_TELEMETRY_DISABLED"
  ],
  "tasks": {
    "generate": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^generate"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["generate", "^generate"]
    },
    "lint": {},
    "dev": {
      "dependsOn": ["^generate"],
      "cache": false,
      "persistent": true
    }
  }
}
