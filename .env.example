# ---------------------------------------------------------------------------
# Progressio environment variables
# Copy to .env (dev/prod compose) or .env.local (bare `npm run dev`) and fill in.
# ---------------------------------------------------------------------------

# --- Database -------------------------------------------------------------
# In Docker compose these point at the "db" service (host = db).
# For a bare local `npm run dev` against the compose DB use:
#   postgresql://progressio:progressio@localhost:5433/progressio
DATABASE_URL=postgresql://progressio:progressio@db:5432/progressio
DIRECT_URL=postgresql://progressio:progressio@db:5432/progressio

# --- App URL --------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Postgres container (used by docker-compose.prod.yml) -----------------
POSTGRES_USER=progressio
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=progressio

# --- Production deploy (Hetzner) ------------------------------------------
# Domain Caddy serves + provisions a TLS cert for.
APP_DOMAIN=progressio.example.com
# GHCR image + tag pulled by docker-compose.prod.yml (tag defaults to "latest").
IMAGE=ghcr.io/samuelslivovsky-cmd/progressio
IMAGE_TAG=latest

# --- Redis ---
REDIS_URL=redis://redis:6379
# --- Auth tokens ---
JWT_ACCESS_SECRET=replace-me-openssl-rand-base64-48
ACCESS_TOKEN_TTL=900       # 15 min (seconds)
REFRESH_TOKEN_TTL=604800   # 7 days (seconds)

# --- AI tier (optional, planned) ------------------------------------------
# ANTHROPIC_API_KEY=
